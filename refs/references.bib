% ============================================================
%  TÀI LIỆU THAM KHẢO – IEEEtran BibTeX format
%  Hướng dẫn: Thêm tài liệu theo mẫu bên dưới
%  Trích dẫn trong văn bản: \cite{key}
% ============================================================

% ---- Tạp chí (Journal Article) ----
@article{example_ref1,
  author    = {Author, First and Author, Second},
  title     = {Title of the Journal Article},
  journal   = {IEEE Transactions on Neural Networks and Learning Systems},
  volume    = {34},
  number    = {5},
  pages     = {1234--1245},
  year      = {2023},
  doi       = {10.1109/TNNLS.2023.XXXXXXX}
}

% ---- Hội nghị (Conference Paper) ----
@inproceedings{example_ref2,
  author    = {Author, Third and Author, Fourth},
  title     = {Title of the Conference Paper},
  booktitle = {Proceedings of the International Conference on Machine Learning (ICML)},
  pages     = {567--578},
  year      = {2022},
  address   = {Baltimore, MD, USA},
  publisher = {PMLR}
}

% ---- Sách (Book) ----
@book{example_book,
  author    = {Bishop, Christopher M.},
  title     = {Pattern Recognition and Machine Learning},
  publisher = {Springer},
  year      = {2006},
  address   = {New York, NY, USA}
}

% ---- Chương sách (Book Chapter) ----
@incollection{example_chapter,
  author    = {Author, Fifth},
  title     = {Chapter Title},
  booktitle = {Book Title},
  editor    = {Editor, Sixth},
  publisher = {Publisher Name},
  pages     = {100--120},
  year      = {2021}
}

% ---- Báo cáo kỹ thuật (Technical Report) ----
@techreport{example_report,
  author      = {Author, Seventh},
  title       = {Title of Technical Report},
  institution = {Institution Name},
  year        = {2020},
  number      = {TR-2020-01}
}

% ---- Tài nguyên online (Online / Website) ----
@misc{example_online,
  author       = {Author, Eighth},
  title        = {Title of Online Resource},
  howpublished = {\url{https://example.com/resource}},
  year         = {2024},
  note         = {Truy cập: 01/01/2025}
}

% ---- Luận văn / Luận án (Thesis) ----
@mastersthesis{example_thesis,
  author  = {Author, Ninth},
  title   = {Title of Master's Thesis},
  school  = {Trường Đại học Công nghiệp TP.HCM},
  year    = {2023},
  type    = {Luận văn thạc sĩ}
}
